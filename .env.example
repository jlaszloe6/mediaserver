# Server network
SERVER_IP=192.168.1.x
LAN_SUBNET=192.168.1.0/24
DNS_UPSTREAM=192.168.1.1

# Media storage mount point
MEDIA_ROOT=/mnt/mediaserver

# Container user (match the mediaserver system user UID/GID)
PUID=1000
PGID=1000

# Backup settings
BACKUP_DIR=/mnt/mediaserver/backups
BACKUP_RETENTION_DAYS=14

# API keys (auto-populated by init-setup.sh from service configs)
PROWLARR_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=

# Jellyfin
JELLYFIN_API_KEY=
JELLYFIN_EXTERNAL_URL=https://${CADDY_DOMAIN_JELLYFIN}

# Email notifications (Brevo SMTP)
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SEERR_SENDER_NAME=Media Server

# Trakt integration (for init-setup.sh --trakt)
SONARR_TRAKT_CLIENT_ID=
RADARR_TRAKT_CLIENT_ID=

# Transmission speed limits (KB/s)
TRANSMISSION_DOWNLOAD_LIMIT_ENABLED=false
TRANSMISSION_DOWNLOAD_LIMIT=0
TRANSMISSION_UPLOAD_LIMIT_ENABLED=true
TRANSMISSION_UPLOAD_LIMIT=50

# Status page
STATUSPAGE_SECRET_KEY=
STATUSPAGE_ALLOWED_EMAILS=user@example.com
STATUSPAGE_BASE_URL=https://mystatus.duckdns.org

# Cloudflare Turnstile (captcha for login)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# MaxMind GeoLite2 (for GeoIP country filtering in Caddy)
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# DuckDNS (for remote access via Caddy)
DUCKDNS_TOKEN=your_duckdns_token
DUCKDNS_SUBDOMAINS=your_duckdns_subdomains
CADDY_DOMAIN_JELLYFIN=myjellyfin.duckdns.org
CADDY_DOMAIN_SEERR=myseerr.duckdns.org
CADDY_DOMAIN_STATUS=mystatus.duckdns.org
