PROWLARR_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=
TAUTULLI_API_KEY=

# Plex (required for Tautulli setup)
PLEX_TOKEN=
PLEX_MACHINE_ID=

# DuckDNS (for remote access via Caddy)
DUCKDNS_TOKEN=your_duckdns_token
DUCKDNS_SUBDOMAINS=your_duckdns_subdomains
